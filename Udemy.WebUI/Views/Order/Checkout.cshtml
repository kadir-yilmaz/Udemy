@{
    ViewData["Title"] = "Odeme";
    var months = ViewBag.ExpireMonths as List<string> ?? new List<string>();
    var years = ViewBag.ExpireYears as List<string> ?? new List<string>();
}
@model CheckoutInfoInput

<div class="row">
    <div class="col-lg-8">
        <form asp-controller="Order" asp-action="Checkout" method="post" id="checkoutForm">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold mb-4"><i class="bi bi-geo-alt-fill text-primary me-2"></i>Adres Bilgileri</h5>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Province" class="form-control" placeholder="Il">
                                <label asp-for="Province">Il</label>
                            </div>
                            <span asp-validation-for="Province" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="District" class="form-control" placeholder="Ilce">
                                <label asp-for="District">Ilce</label>
                            </div>
                            <span asp-validation-for="District" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <input asp-for="Street" class="form-control" placeholder="Cadde/Sokak">
                                <label asp-for="Street">Cadde/Sokak</label>
                            </div>
                            <span asp-validation-for="Street" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <input asp-for="Line" class="form-control" placeholder="Adres Detayi">
                                <label asp-for="Line">Adres Detayi / Bina No</label>
                            </div>
                            <span asp-validation-for="Line" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="ZipCode" class="form-control" placeholder="Posta Kodu">
                                <label asp-for="ZipCode">Posta Kodu</label>
                            </div>
                            <span asp-validation-for="ZipCode" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold mb-4"><i class="bi bi-credit-card-2-front-fill text-primary me-2"></i>Odeme Bilgileri</h5>

                    <div class="row g-3">
                        <div class="col-12">
                            <div class="form-floating">
                                <input asp-for="CardName" class="form-control" placeholder="Kart Uzerindeki Isim">
                                <label asp-for="CardName">Kart Uzerindeki Isim Soyisim</label>
                            </div>
                            <span asp-validation-for="CardName" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <input asp-for="CardNumber" class="form-control" placeholder="Kart Numarasi" inputmode="numeric" maxlength="16" pattern="\d{16}">
                                <label asp-for="CardNumber">Kart Numarasi</label>
                            </div>
                            <span asp-validation-for="CardNumber" class="text-danger small"></span>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Son Kullanma Tarihi</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <select asp-for="ExpireMonth" class="form-select">
                                        <option value="">Ay</option>
                                        @foreach (var month in months)
                                        {
                                            <option value="@month">@month</option>
                                        }
                                    </select>
                                    <span asp-validation-for="ExpireMonth" class="text-danger small"></span>
                                </div>
                                <div class="col-6">
                                    <select asp-for="ExpireYear" class="form-select">
                                        <option value="">Yil</option>
                                        @foreach (var year in years)
                                        {
                                            <option value="@year">@year</option>
                                        }
                                    </select>
                                    <span asp-validation-for="ExpireYear" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input asp-for="CVV" class="form-control" placeholder="CVV" inputmode="numeric" maxlength="3" pattern="\d{3}" style="max-width: 160px;">
                                <label asp-for="CVV">CVV / CVC</label>
                            </div>
                            <span asp-validation-for="CVV" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-lg-none mb-4">
                <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm">
                    <i class="bi bi-lock-fill me-2"></i> @ViewBag.basket.TotalPrice TL Ode
                </button>
            </div>
        </form>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm border-0 sticky-top" style="top: 2rem; z-index: 1000;">
            <div class="card-body p-4">
                <h5 class="card-title fw-bold mb-3">Siparis Ozeti</h5>

                @if (ViewBag.basket != null)
                {
                    <div class="list-group list-group-flush mb-3">
                        @foreach (var item in ViewBag.basket.BasketItems as List<BasketItemViewModel>)
                        {
                            <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-0 text-truncate" style="max-width: 200px;" title="@item.CourseName">@item.CourseName</h6>
                                </div>
                                <span class="text-muted">@item.Price TL</span>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">@(ViewBag.basket.HasDiscount ? "Indirimli Tutar" : "Toplam Tutar")</span>
                        <span class="fs-4 fw-bold text-primary">@ViewBag.basket.TotalPrice TL</span>
                    </div>
                }

                @if (ViewBag.error != null)
                {
                    <div class="alert alert-danger d-flex align-items-center mt-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2"></i>
                        <div>@ViewBag.error</div>
                    </div>
                }
            </div>
            <div class="card-footer bg-white border-0 p-4 pt-0">
                <button type="submit" form="checkoutForm" class="btn btn-success w-100 py-3 fw-bold shadow-sm">
                    <i class="bi bi-lock-fill me-2"></i> Guvenli Odeme Yap
                </button>
                <div class="text-center mt-3">
                    <small class="text-muted"><i class="bi bi-shield-check"></i> Odemeniz 256-bit SSL ile korunmaktadir.</small>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />

<script>
    document.addEventListener("input", function (event) {
        if (event.target.name === "CardNumber" || event.target.name === "CVV") {
            event.target.value = event.target.value.replace(/\D/g, "");
        }
    });
</script>
