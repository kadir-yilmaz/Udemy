@{
    ViewData["Title"] = "Ödeme";
}
@model CheckoutInfoInput

<div class="row">
    <div class="col-lg-8">
        <form asp-controller="Order" asp-action="Checkout" method="post" id="checkoutForm">
            <!-- Adres Bilgileri -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold mb-4"><i class="bi bi-geo-alt-fill text-primary me-2"></i>Adres Bilgileri</h5>
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Province" class="form-control" placeholder="İl">
                                <label asp-for="Province">İl</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="District" class="form-control" placeholder="İlçe">
                                <label asp-for="District">İlçe</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <input asp-for="Street" class="form-control" placeholder="Cadde/Sokak">
                                <label asp-for="Street">Cadde/Sokak</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <input asp-for="Line" class="form-control" placeholder="Adres Tarifi">
                                <label asp-for="Line">Adres Detayı / Bina No</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="ZipCode" class="form-control" placeholder="Posta Kodu">
                                <label asp-for="ZipCode">Posta Kodu</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Ödeme Bilgileri -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold mb-4"><i class="bi bi-credit-card-2-front-fill text-primary me-2"></i>Ödeme Bilgileri</h5>
                    
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="form-floating">
                                <input asp-for="CardName" class="form-control" placeholder="Kart Üzerindeki İsim">
                                <label asp-for="CardName">Kart Üzerindeki İsim Soyisim</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <input asp-for="CardNumber" class="form-control" placeholder="Kart Numarası">
                                <label asp-for="CardNumber">Kart Numarası</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Expiration" class="form-control" placeholder="Ay/Yıl">
                                <label asp-for="Expiration">Son Kullanma Tarihi (Ay/Yıl)</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="CVV" class="form-control" placeholder="CVV">
                                <label asp-for="CVV">CVV / CVC</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mobile Submit Button (Visible only on small screens) -->
            <div class="d-lg-none mb-4">
                 <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm">
                    <i class="bi bi-lock-fill me-2"></i> @ViewBag.basket.TotalPrice TL Öde
                </button>
            </div>
        </form>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm border-0 sticky-top" style="top: 2rem; z-index: 1000;">
            <div class="card-body p-4">
                <h5 class="card-title fw-bold mb-3">Sipariş Özeti</h5>

                 @if (ViewBag.basket != null)
                {
                    <div class="list-group list-group-flush mb-3">
                         @foreach (var item in ViewBag.basket.BasketItems as List<BasketItemViewModel>)
                        {
                            <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-0 text-truncate" style="max-width: 200px;" title="@item.CourseName">@item.CourseName</h6>
                                </div>
                                <span class="text-muted">@item.Price TL</span>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">@(ViewBag.basket.HasDiscount ? "İndirimli Tutar" : "Toplam Tutar")</span>
                        <span class="fs-4 fw-bold text-primary">@ViewBag.basket.TotalPrice TL</span>
                    </div>
                }

                @if (ViewBag.error != null)
                {
                    <div class="alert alert-danger d-flex align-items-center mt-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2"></i>
                        <div>@ViewBag.error</div>
                    </div>
                }
                
                <!-- Desktop Submit Button (Form external trigger via JS or just place inside form if we wrap everything, 
                     BUT simplest is to use form="ID" attribute on button, but asp-helper might not support it easily without explicit HTML.
                     Actually, the Form is in the left column. The submit button needs to be inside the form or linked.
                     Given the structure, I will MOVE the form tag to wrap the ENTIRE row, so the button in right col is inside the form.
                     -->
            </div>
             <div class="card-footer bg-white border-0 p-4 pt-0">
                  <button type="submit" form="checkoutForm" class="btn btn-success w-100 py-3 fw-bold shadow-sm">
                    <i class="bi bi-lock-fill me-2"></i> Güvenli Ödeme Yap
                </button>
                <div class="text-center mt-3">
                    <small class="text-muted"><i class="bi bi-shield-check"></i> Ödemeniz 256-bit SSL ile korunmaktadır.</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Re-adjusted Form Tag Wrapping logic or ID linking -->
<!-- Since I cannot easily wrap the whole row without potentially breaking layout if not careful, 
     I will add 'id="checkoutForm"' to the form tag in the left column, 
     and use 'form="checkoutForm"' for the button in the right column. 
     This allows keeping the semantic structure separate while functionally connected. -->

<script>
    // Just in case form attribute isn't fully supported in some very old browsers (unlikely for modern web), but good to know.
    // Modern browsers support 'form' attribute on buttons.
</script>
