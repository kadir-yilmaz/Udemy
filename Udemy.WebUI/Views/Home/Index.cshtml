@{
    ViewData["Title"] = "Tüm Kurslar";
}
@model List<CourseViewModel>

<style>
    .course-card {
        border: none;
        border-radius: 0;
        transition: all 0.3s ease;
        overflow: hidden;
    }
    .course-card:hover {
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        transform: translateY(-4px);
    }
    .course-image-wrapper {
        position: relative;
        width: 100%;
        padding-top: 56.25%; /* 16:9 Aspect Ratio */
        overflow: hidden;
        background-color: #f7f9fa;
    }
    .course-image-wrapper img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .course-card .card-body {
        padding: 1rem;
    }
    .course-title {
        font-size: 1rem;
        font-weight: 700;
        color: #1c1d1f;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 0.25rem;
    }
    .course-instructor {
        font-size: 0.75rem;
        color: #6a6f73;
        margin-bottom: 0.25rem;
    }
    .course-description {
        font-size: 0.8rem;
        color: #6a6f73;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 0.5rem;
    }
    .course-category {
        font-size: 0.7rem;
        background-color: #eceb98;
        color: #3d3c0a;
        padding: 0.15rem 0.5rem;
        font-weight: 600;
    }
    .course-price {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1c1d1f;
    }
    .course-price-old {
        font-size: 0.9rem;
        color: #6a6f73;
        text-decoration: line-through;
        margin-left: 0.5rem;
    }
    .bestseller-badge {
        background-color: #eceb98;
        color: #3d3c0a;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 0.25rem 0.5rem;
        display: inline-block;
        margin-bottom: 0.5rem;
    }
    .section-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1c1d1f;
        margin-bottom: 1rem;
    }
</style>

<div class="container py-4">
    <h2 class="section-title">Tüm Kurslar</h2>
    
    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3">
            @foreach (var item in Model)
            {
                <div class="col">
                    <a asp-controller="Home" asp-action="Detail" asp-route-id="@item.Id" class="text-decoration-none">
                        <div class="card course-card h-100">
                            <div class="course-image-wrapper">
                                <img src="@(item.StockPictureUrl ?? "https://via.placeholder.com/480x270?text=Kurs+Resmi")" alt="@item.Name">
                            </div>
                            <div class="card-body d-flex flex-column">
                                <h5 class="course-title">@item.Name</h5>
                                <div class="course-instructor">
                                    @(item.UserName ?? "Eğitmen")
                                </div>
                                <p class="course-description">@item.ShortDescription</p>
                                <span class="course-category mb-2">@(item.Category?.Name ?? "Genel")</span>
                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                    @if (ViewBag.OwnedCourseIds != null && ((List<string>)ViewBag.OwnedCourseIds).Contains(item.Id))
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">
                                            <i class="bi bi-check-circle-fill me-1"></i>SAHİPSİNİZ
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="course-price">₺@item.Price.ToString("N2")</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-collection-play" style="font-size: 4rem; color: #d1d7dc;"></i>
            <h4 class="mt-3 text-muted">Henüz kurs bulunmamaktadır</h4>
            <p class="text-muted">Yeni kurslar eklendiğinde burada görünecektir.</p>
        </div>
    }
</div>


@if (TempData["OrderSuccess"] != null && (bool)TempData["OrderSuccess"] == true)
{
    <div class="modal fade" id="orderSuccessModal" tabindex="-1" aria-labelledby="orderSuccessModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-center p-4">
                <div class="modal-body">
                    <div class="mb-3 text-success">
                        <i class="bi bi-check-circle-fill display-1"></i>
                    </div>
                    <h3 class="fw-bold mb-3">Ödeme Başarılı!</h3>
                    <p class="text-muted mb-4">Siparişiniz başarıyla oluşturuldu. Teşekkür ederiz.</p>
                    
                    @if (TempData["OrderId"] != null)
                    {
                        <div class="alert alert-light border d-inline-block px-4 py-2 mb-4">
                            <strong>Sipariş No:</strong> @TempData["OrderId"]
                        </div>
                    }

                    <div class="d-grid gap-2">
                        <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Alışverişe Devam Et</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        // Wait for DOM to load then show modal
        document.addEventListener("DOMContentLoaded", function () {
            var myModal = new bootstrap.Modal(document.getElementById('orderSuccessModal'));
            myModal.show();
        });
    </script>
}
