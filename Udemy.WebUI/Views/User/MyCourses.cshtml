@using Udemy.WebUI.Models.Orders
@{
    ViewData["Title"] = "Kurslarım";
}

@model List<OrderItemViewModel>

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold text-primary mb-1">Kurslarım</h2>
        <p class="text-muted">Satın aldığınız tüm kurslar</p>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
            @foreach (var course in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="position-relative">
                            <img src="@course.PictureUrl" 
                                 onerror="this.onerror=null;this.src='https://via.placeholder.com/640x360?text=Kurs+Resmi';"
                                 class="card-img-top" 
                                 alt="@course.ProductName"
                                 style="height: 160px; object-fit: cover;" 
                                 onerror="this.onerror=null;this.src='https://via.placeholder.com/320x180?text=Resim+Yuklenemedi';" />
                            
                            <div class="position-absolute top-0 end-0 m-2">
                                <span class="badge bg-dark bg-opacity-75">
                                    <i class="bi bi-play-circle"></i>
                                </span>
                            </div>
                        </div>
                        <div class="card-body">
                            <h6 class="card-title fw-bold mb-2 text-truncate" title="@course.ProductName">
                                @course.ProductName
                            </h6>
                            <div class="progress mb-2" style="height: 4px;">
                                <div class="progress-bar bg-primary" role="progressbar" style="width: 0%"></div>
                            </div>
                            <small class="text-muted">Başlamadınız</small>
                        </div>
                        <div class="card-footer bg-transparent border-0 pt-0">
                            <a href="#" class="btn btn-primary btn-sm w-100">
                                <i class="bi bi-play-fill"></i> Kursa Başla
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-collection-play display-1 text-muted"></i>
                <h5 class="mt-3 text-muted">Henüz bir kurs satın almadınız</h5>
                <p class="text-muted">Hemen bir kursa göz atın ve öğrenmeye başlayın!</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-search"></i> Kursları Keşfet
                </a>
            </div>
        </div>
    }
</div>
