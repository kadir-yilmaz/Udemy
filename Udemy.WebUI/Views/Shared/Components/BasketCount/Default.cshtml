@model int

@if (Model > 0)
{
    <span class="position-absolute badge rounded-circle" style="top: -5px; left: 10px; font-size: 0.6rem; padding: 0.3em 0.5em; background-color: #f5a623; color: white; min-width: 18px; height: 18px; display: flex; align-items: center; justify-content: center;">
        @Model
    </span>
}
