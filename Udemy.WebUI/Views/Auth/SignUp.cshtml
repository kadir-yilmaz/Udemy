@{
    ViewData["Title"] = "Kayıt Ol";
    Layout = "_Layout";
}
@model Udemy.WebUI.Models.SignUpInput

<style>
    .auth-container {
        max-width: 400px;
        margin: 2rem auto;
    }
    .auth-header {
        text-align: center;
        margin-bottom: 1.5rem;
    }
    .auth-header h2 {
        font-weight: 700;
        color: #1c1d1f;
        font-size: 1.5rem;
    }
    .auth-header p {
        color: #6a6f73;
        font-size: 0.9rem;
    }
    .auth-form {
        background: #fff;
        border: 1px solid #d1d7dc;
        padding: 2rem;
    }
    .auth-form .form-label {
        font-weight: 700;
        font-size: 0.85rem;
        color: #1c1d1f;
    }
    .auth-form .form-control {
        border: 1px solid #1c1d1f;
        border-radius: 0;
        padding: 0.75rem 1rem;
        font-size: 1rem;
    }
    .auth-form .form-control:focus {
        border-color: #5624d0;
        box-shadow: 0 0 0 1px #5624d0;
    }
    .btn-auth {
        width: 100%;
        background-color: #a435f0;
        color: #fff;
        border: none;
        padding: 0.85rem;
        font-weight: 700;
        font-size: 1rem;
    }
    .btn-auth:hover {
        background-color: #8710d8;
        color: #fff;
    }
    .auth-footer {
        text-align: center;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #d1d7dc;
    }
    .auth-footer a {
        color: #5624d0;
        font-weight: 700;
        text-decoration: none;
    }
    .auth-footer a:hover {
        color: #401b9c;
        text-decoration: underline;
    }
</style>

<div class="container py-4">
    <div class="auth-container">
        <div class="auth-header">
            <h2>Kaydolun ve öğrenmeye başlayın</h2>
            <p>Binlerce kurs sizi bekliyor</p>
        </div>

        <div class="auth-form">


            <form asp-controller="Auth" asp-action="SignUp" method="post">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger mb-3 py-2 small shadow-sm border-start border-danger border-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@Html.Raw(TempData["ErrorMessage"])
                    </div>
                }
                <div class="mb-3 row">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label">Ad</label>
                        <input type="text" asp-for="Name" class="form-control" placeholder="Adınız" autocomplete="off">
                        <span class="text-danger small" asp-validation-for="Name"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Surname" class="form-label">Soyad</label>
                        <input type="text" asp-for="Surname" class="form-control" placeholder="Soyadınız" autocomplete="off">
                        <span class="text-danger small" asp-validation-for="Surname"></span>
                    </div>
                </div>


                
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">E-posta</label>
                    <input type="email" asp-for="Email" class="form-control" placeholder="ornek@email.com" autocomplete="off">
                    <span class="text-danger small" asp-validation-for="Email"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Şifre</label>
                    <input type="password" asp-for="Password" class="form-control" placeholder="En az 6 karakter" autocomplete="new-password">
                    <span class="text-danger small" asp-validation-for="Password"></span>
                </div>
                

                
                <button type="submit" class="btn btn-auth">
                    <i class="bi bi-person-plus me-2"></i>Kayıt Ol
                </button>

                <p class="text-center text-muted small mt-3">
                    Kaydolarak <a href="#" class="text-decoration-underline">Kullanım Koşulları</a>'nı ve 
                    <a href="#" class="text-decoration-underline">Gizlilik Politikası</a>'nı kabul etmiş olursunuz.
                </p>
            </form>

            <div class="auth-footer">
                Zaten hesabınız var mı? <a asp-action="SignIn">Giriş Yapın</a>
            </div>
        </div>
    </div>
</div>
