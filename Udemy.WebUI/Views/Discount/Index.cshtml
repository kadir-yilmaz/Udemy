@using Udemy.WebUI.Models.Discounts
@{
    ViewData["Title"] = "İndirim Kuponları";
}

@model List<DiscountViewModel>

<div class="row">
    <div class="col-md-12 mb-3">
        <div class="d-flex justify-content-between align-items-center">
            <h2>İndirim Kuponları</h2>
            <a asp-action="Create" class="btn btn-primary">Yeni Kupon Oluştur</a>
        </div>
    </div>
    
    <div class="col-md-12">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Kod</th>
                            <th>Oran (%)</th>
                            <th>Kullanıcı ID</th>
                            <th>Oluşturulma Tarihi</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Code</td>
                                <td>%@item.Rate</td>
                                <td>@item.UserId</td>
                                <td>@item.CreatedTime.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Silmek istediğinize emin misiniz?')">Sil</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                Henüz oluşturulmuş indirim kuponu bulunmamaktadır.
            </div>
        }
    </div>
</div>
