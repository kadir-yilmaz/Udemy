@{
    ViewData["Title"] = "Yeni Kurs Oluştur";
}
@model CourseCreateInput

<style>
    .form-container {
        max-width: 700px;
        margin: 0 auto;
    }
    .form-header {
        text-align: center;
        margin-bottom: 2rem;
    }
    .form-header h2 {
        font-weight: 700;
        color: #1c1d1f;
    }
    .form-header p {
        color: #6a6f73;
    }
    .form-section {
        background: #fff;
        border: 1px solid #d1d7dc;
        padding: 1.5rem;
        margin-bottom: 1rem;
    }
    .form-section-title {
        font-weight: 700;
        font-size: 1rem;
        color: #1c1d1f;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #e8e9eb;
    }
    .form-label {
        font-weight: 600;
        color: #1c1d1f;
        font-size: 0.9rem;
    }
    .form-control {
        border: 1px solid #1c1d1f;
        border-radius: 0;
        padding: 0.75rem;
    }
    .form-control:focus {
        border-color: #5624d0;
        box-shadow: 0 0 0 1px #5624d0;
    }
    .form-select {
        border: 1px solid #1c1d1f;
        border-radius: 0;
        padding: 0.75rem;
    }
    .btn-submit {
        background-color: #1c1d1f;
        color: #fff;
        border: none;
        padding: 0.75rem 1.5rem;
        font-weight: 700;
        width: 100%;
    }
    .btn-submit:hover {
        background-color: #3e4143;
        color: #fff;
    }
    .file-upload {
        border: 2px dashed #d1d7dc;
        padding: 2rem;
        text-align: center;
        background-color: #f7f9fa;
        cursor: pointer;
        transition: all 0.2s;
    }
    .file-upload:hover {
        border-color: #5624d0;
        background-color: #f0f0ff;
    }
    .file-upload i {
        font-size: 2rem;
        color: #6a6f73;
    }
</style>

<div class="container py-4">
    <div class="form-container">
        <div class="form-header">
            <h2><i class="bi bi-plus-circle"></i> Yeni Kurs Oluştur</h2>
            <p>Kursunuzun temel bilgilerini girerek başlayın</p>
        </div>

        <form asp-controller="Courses" asp-action="Create" method="post" enctype="multipart/form-data">
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert alert-danger mb-3">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Lütfen aşağıdaki hataları düzeltin:</strong>
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <div class="form-section">
                <h6 class="form-section-title"><i class="bi bi-info-circle me-2"></i>Temel Bilgiler</h6>
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Kurs Başlığı <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" placeholder="Örn: Python ile Sıfırdan Uzmanlığa" />
                    <span class="text-danger small" asp-validation-for="Name"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Kurs Açıklaması <span class="text-danger">*</span></label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Kursunuzu detaylı şekilde açıklayın..."></textarea>
                    <span class="text-danger small" asp-validation-for="Description"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label">Kategori <span class="text-danger">*</span></label>
                    <select asp-for="CategoryId" class="form-select" asp-items="@ViewBag.categoryList">
                        <option value="">Kategori seçiniz</option>
                    </select>
                    <span class="text-danger small" asp-validation-for="CategoryId"></span>
                </div>
            </div>

            <div class="form-section">
                <h6 class="form-section-title"><i class="bi bi-currency-dollar me-2"></i>Fiyat & Süre</h6>
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label">Fiyat (₺) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">₺</span>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" placeholder="99.99" />
                        </div>
                        <span class="text-danger small" asp-validation-for="Price"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Feature.Duration" class="form-label">Süre (saat)</label>
                        <div class="input-group">
                            <input asp-for="Feature.Duration" class="form-control" type="number" placeholder="10" />
                            <span class="input-group-text">saat</span>
                        </div>
                        <span class="text-danger small" asp-validation-for="Feature.Duration"></span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h6 class="form-section-title"><i class="bi bi-image me-2"></i>Kurs Görseli</h6>
                
                <div class="mb-3">
                    <label class="file-upload w-100" for="PhotoFormFile" id="drop-zone">
                        <div id="upload-placeholder">
                            <i class="bi bi-cloud-arrow-up d-block mb-2"></i>
                            <span>Görsel yüklemek için tıklayın veya sürükleyin</span>
                            <small class="d-block text-muted mt-1">PNG, JPG (önerilen: 750x422 px)</small>
                        </div>
                        <img id="imagePreview" src="" alt="Görsel Önizleme" class="img-fluid d-none" style="max-height: 300px; object-fit: contain;" />
                    </label>
                    <input type="file" asp-for="PhotoFormFile" id="PhotoFormFile" class="d-none" accept="image/*" onchange="previewImage(this)" />
                    <span class="text-danger small" asp-validation-for="PhotoFormFile"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-submit">
                <i class="bi bi-check-circle me-2"></i>Kursu Oluştur
            </button>
        </form>
    </div>
</div>

<script>
    function previewImage(input) {
        var placeholder = document.getElementById('upload-placeholder');
        var preview = document.getElementById('imagePreview');
        
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            
            reader.onload = function(e) {
                preview.src = e.target.result;
                preview.classList.remove('d-none');
                placeholder.classList.add('d-none');
            }
            
            reader.readAsDataURL(input.files[0]);
        } else {
             preview.classList.add('d-none');
             placeholder.classList.remove('d-none');
        }
    }
</script>
