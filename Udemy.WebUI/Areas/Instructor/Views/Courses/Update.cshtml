@{
    ViewData["Title"] = "Kurs Güncelle";
}
@model CourseUpdateInput

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold"><i class="bi bi-pencil me-2"></i>Kurs Güncelle</h5>
            </div>
            <div class="card-body">
                <form asp-area="Instructor" asp-controller="Courses" asp-action="Update" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="Picture" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Kurs Başlığı</label>
                        <input asp-for="Name" class="form-control" />
                        <span class="text-danger" asp-validation-for="Name"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Kurs Açıklaması</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span class="text-danger" asp-validation-for="Description"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label">Kategori</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="@ViewBag.categoryList"></select>
                        <span class="text-danger" asp-validation-for="CategoryId"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Price" class="form-label">Fiyat (₺)</label>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" />
                            <span class="text-danger" asp-validation-for="Price"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Feature.Duration" class="form-label">Süre (saat)</label>
                            <input asp-for="Feature.Duration" class="form-control" type="number" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Kurs Görseli</label>
                        <input type="file" asp-for="PhotoFormFile" class="form-control" accept="image/*" />
                        <small class="text-muted">Yeni görsel yüklemezseniz mevcut görsel korunur.</small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>Güncelle
                        </button>
                        <a asp-area="Instructor" asp-controller="Courses" asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
