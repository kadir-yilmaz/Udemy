@{
    ViewData["Title"] = "Kurslarım";
}
@model List<CourseViewModel>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Kurslarım</h4>
    <a asp-area="Instructor" asp-controller="Courses" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Yeni Kurs
    </a>
</div>

@if (Model != null && Model.Any())
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 80px;">Resim</th>
                        <th>Kurs Adı</th>
                        <th>Fiyat</th>
                        <th>Süre</th>
                        <th>Kategori</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><img style="width:60px; height:40px; object-fit:cover;" src="@(item.StockPictureUrl ?? "https://via.placeholder.com/60x40?text=Yok")" class="rounded" /></td>
                            <td class="fw-semibold">@item.Name</td>
                            <td>@item.Price TL</td>
                            <td>@item.Feature?.Duration saat</td>
                            <td><span class="badge bg-secondary">@item.Category?.Name</span></td>
                            <td class="text-end">
                                <a asp-area="Instructor" asp-controller="Courses" asp-action="Update" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-area="Instructor" asp-controller="Courses" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <p class="text-muted mt-3">Henüz bir kursunuz yok.</p>
            <a asp-area="Instructor" asp-controller="Courses" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> İlk Kursunuzu Oluşturun
            </a>
        </div>
    </div>
}
