@{
    ViewData["Title"] = "Dashboard";
}
@model List<Udemy.WebUI.Models.Catalogs.CourseViewModel>

<div class="row mb-4">
    <div class="col-12">
        <h2 class="fw-bold">Hoş Geldiniz, @User.Identity?.Name!</h2>
        <p class="text-muted">Eğitmen panelinize hoş geldiniz. Buradan kurslarınızı ve indirim kuponlarınızı yönetebilirsiniz.</p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-subtitle mb-2 opacity-75">Toplam Kurs</h6>
                        <h2 class="card-title mb-0 fw-bold">@ViewBag.TotalCourses</h2>
                    </div>
                    <i class="bi bi-collection-play display-4 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">Kurslarım</h5>
            <a asp-area="Instructor" asp-controller="Courses" asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle"></i> Yeni Kurs
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Kurs Adı</th>
                            <th>Fiyat</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var course in Model)
                        {
                            <tr>
                                <td>@course.Name</td>
                                <td>@course.Price TL</td>
                                <td class="text-end">
                                    <a asp-area="Instructor" asp-controller="Courses" asp-action="Update" asp-route-id="@course.Id" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox display-1 text-muted"></i>
                <p class="text-muted mt-3">Henüz bir kursunuz yok.</p>
                <a asp-area="Instructor" asp-controller="Courses" asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> İlk Kursunuzu Oluşturun
                </a>
            </div>
        }
    </div>
</div>
