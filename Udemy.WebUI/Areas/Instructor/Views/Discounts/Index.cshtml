@using Udemy.WebUI.Models.Discounts
@{
    ViewData["Title"] = "İndirim Kuponları";
}

@model List<DiscountViewModel>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">İndirim Kuponları</h4>
    <a asp-area="Instructor" asp-controller="Discounts" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Yeni Kupon
    </a>
</div>

@if (Model != null && Model.Any())
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Kod</th>
                        <th>Oran</th>
                        <th>Son Kullanma</th>
                        <th>Oluşturulma</th>
                        <th class="text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge bg-primary">@item.Code</span></td>
                            <td><span class="fw-bold text-success">%@item.Rate</span></td>
                            <td>@(item.ExpirationDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                            <td>@item.CreatedTime.ToString("dd.MM.yyyy")</td>
                            <td class="text-end">
                                <a asp-area="Instructor" asp-controller="Discounts" asp-action="Delete" asp-route-id="@item.Id" 
                                   class="btn btn-outline-danger btn-sm" onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-tags display-1 text-muted"></i>
            <p class="text-muted mt-3">Henüz bir indirim kuponu oluşturmadınız.</p>
            <a asp-area="Instructor" asp-controller="Discounts" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> İlk Kuponunuzu Oluşturun
            </a>
        </div>
    </div>
}
